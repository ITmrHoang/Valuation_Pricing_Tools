# === AI Pricing Engine Environment Variables ===

# Server
SERVER_HOST=127.0.0.1
SERVER_PORT=8080

# Database
DATABASE_URL=sqlite://data/pricing.db

# Logging
RUST_LOG=info

# OpenSea API
OPENSEA_API_KEY=your_opensea_api_key_here

# Magic Eden API
MAGIC_EDEN_API_KEY=your_magic_eden_api_key_here

# Blur API
BLUR_API_KEY=your_blur_api_key_here

# CrewAI
CREW_AI_WEBHOOK_SECRET=your_webhook_secret_here

# Proxy Pool (tuỳ chọn)
PROXY_ENABLED=false
# PROXY_1=http://user:pass@proxy1.example.com:8080
# PROXY_2=socks5://user:pass@proxy2.example.com:1080
